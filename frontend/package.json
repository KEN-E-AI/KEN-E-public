  "scripts": {
    "dev": "vite",
    "dev:development": "node scripts/resolve-secrets.js .env.development && vite --mode development",
    "dev:staging": "node scripts/resolve-secrets.js .env.staging && vite --mode staging",
    "dev:production": "node scripts/resolve-secrets.js .env.production && vite --mode production",
    "build": "vite build",
    "build:staging": "node scripts/resolve-secrets.js .env.staging && vite build --mode staging",
    "build:production": "node scripts/resolve-secrets.js .env.production && vite build --mode production",
    "resolve-secrets": "node scripts/resolve-secrets.js",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest --run",
    "format.fix": "prettier --write .",
    "typecheck": "tsc -b",
    "test:e2e": "playwright test"
  },
