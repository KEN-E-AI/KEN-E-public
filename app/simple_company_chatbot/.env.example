# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=google-cloud-service-account-key.json
GOOGLE_GENAI_USE_VERTEXAI=True

# Vertex AI Configuration for Agent Engine Deployment
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_STAGING_BUCKET=your-vertex-ai-staging-bucket

# Vertex AI Search Configuration (update with your actual IDs)
VERTEX_AI_SEARCH_ENGINE_ID=your-search-engine-id
VERTEX_AI_SERVING_CONFIG_ID=default_config

# NewsAPI.ai Configuration
NEWSAPI_AI_KEY=your_newsapi_key_here

# Google Analytics MCP Server Configuration
GA_MCP_SERVER_URL=https://your-ga-mcp-server.run.app
GA_TENANT_ID=your-tenant-id
GA_TENANT_CREDENTIALS=your_base64_encoded_credentials

# W&B/Weave Configuration for observability
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=your-wandb-project-name
WEAVE_PROJECT_NAME=your-weave-project-name