# Vertex AI Configuration with Service Account
GOOGLE_CLOUD_PROJECT_ID=ken-e-production
VERTEX_AI_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT=ken-e-production
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
VERTEX_AI_STAGING_BUCKET=ken-e-production-vertex-ai-staging

# Neo4j Database Configuration (Production)
NEO4J_URI=sm://395770269870/NEO4J_URI
NEO4J_USERNAME=sm://395770269870/NEO4J_USERNAME
NEO4J_PASSWORD=sm://395770269870/NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# Firestore Configuration
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_PROJECT_ID=ken-e-production

# Environment Indicator
ENVIRONMENT=production
LOG_LEVEL=INFO

# Vertex AI Search Configuration
VERTEX_AI_SEARCH_ENGINE_ID=production-strategy-docs-id
VERTEX_AI_SERVING_CONFIG_ID=default_config

# Company News Chatbot - Vertex AI Search Datastore
VERTEX_AI_NEWS_DATASTORE_ID=ken-e-production-news-search-datastore
VERTEX_AI_SEARCH_LOCATION=global

# NewsAPI.ai Configuration
NEWSAPI_AI_KEY=sm://395770269870/newsapi-ai-key

# Google Analytics MCP Server Configuration
GA_MCP_SERVER_URL=https://google-analytics-mcp-4quwenkusq-uc.a.run.app
GA_TENANT_ID=ken-e-production
GA_TENANT_CREDENTIALS=sm://395770269870/ga-tenant-credentials

# Weights & Biases / Weave Observability
WANDB_API_KEY=sm://395770269870/wandb_api_key
WANDB_PROJECT=ken-e-prod
WEAVE_PROJECT_NAME=ken-e-prod
WANDB_ENTITY=ken-e

# Agent Engine IDs (Managed via Secret Manager)
KEN_E_ENGINE_ID=sm://395770269870/ken-e-engine-id
STRATEGY_SUPERVISOR_ENGINE_ID=sm://395770269870/strategy-supervisor-engine-id

# OpenAI API Key (for strategy formatters)
OPENAI_API_KEY=sm://395770269870/OPENAI_API_KEY

# Apache Superset Configuration
SUPERSET_BASE_URL=https://superset.ken-e.ai
SUPERSET_USERNAME=api
SUPERSET_PASSWORD=sm://395770269870/superset-password

# SendGrid Email Service
SENDGRID_API_KEY=sm://395770269870/sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@ken-e.ai
EMAIL_FROM_NAME=KEN-E Team
APP_BASE_URL=https://app.ken-e.ai

# reCAPTCHA Configuration
RECAPTCHA_SITE_KEY=sm://395770269870/recaptcha-site-key
RECAPTCHA_SECRET_KEY=sm://395770269870/recaptcha-secret-key

# OAuth Configuration (production-specific)
GOOGLE_OAUTH_CLIENT_ID=YOUR_PRODUCTION_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=sm://395770269870/GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://kene-api-prod-395770269870.us-central1.run.app/api/oauth/callback/google
FRONTEND_URL=https://kene-frontend-prod-395770269870.us-central1.run.app

# Encryption Key (production-specific)
ENCRYPTION_KEY=sm://395770269870/ENCRYPTION_KEY

# OpenTelemetry / Agent Engine Telemetry Configuration
# https://docs.cloud.google.com/agent-builder/agent-engine/manage/tracing
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
OTEL_SDK_DISABLED=false
# Only the buggy google-genai instrumentation is disabled (crashes output_schema agents)
OTEL_PYTHON_DISABLED_INSTRUMENTATIONS=google-genai
