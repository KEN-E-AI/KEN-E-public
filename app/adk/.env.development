# Environment variables for Kene API - Development Environment
#
# ============================================================================
# SECRET MANAGER INTEGRATION
# ============================================================================
# This file supports Google Secret Manager references for sensitive credentials.
# Variables with sm:// prefix will be resolved from Secret Manager at runtime.
# Example: VARIABLE_NAME=sm://project_id/secret_name
# ============================================================================

# Neo4j Aura Development Instance
NEO4J_URI=sm://NEO4J_URI
NEO4J_USERNAME=sm://NEO4J_USERNAME
NEO4J_PASSWORD=sm://NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# Google Cloud Configuration (for Firestore)
# Use ken-e-dev for Firebase Auth validation (matches frontend tokens)
GOOGLE_CLOUD_PROJECT_ID=ken-e-dev
GOOGLE_CLOUD_PROJECT=ken-e-dev
# GOOGLE_APPLICATION_CREDENTIALS=/Users/dvalia/Code/python/KEN-E/api/ken-e-dev.json
FIRESTORE_DATABASE_ID=(default)

# For local development, we'll use ken-e-dev for Firebase/Firestore but ken-e-staging for Agent Engine
FIRESTORE_PROJECT_ID=ken-e-dev

# Agent Engine project (now using development project)
VERTEX_AI_PROJECT_ID=ken-e-dev
# Using same credentials as main project since Agent Engine is in dev project
# VERTEX_AI_CREDENTIALS=/Users/dvalia/Code/python/KEN-E/api/ken-e-dev.json

# Logging
LOG_LEVEL=DEBUG

# Environment indicator
ENVIRONMENT=development

# Apache Superset Configuration
SUPERSET_BASE_URL=https://superset.ken-e.ai
SUPERSET_USERNAME=api
SUPERSET_PASSWORD=sm://superset-password
SUPERSET_DATABASE_ID=1

SENDGRID_API_KEY=sm://sendgrid-api-key

# Recaptcha
RECAPTCHA_SITE_KEY=sm://recaptcha-site-key
RECAPTCHA_SECRET_KEY=sm://recaptcha-secret-key

# Company News Chatbot - Vertex AI Search Datastore
# Dev reuses staging datastore since no separate dev datastore exists
VERTEX_AI_NEWS_DATASTORE_ID=ken-e-staging-test-news-search-connecto_1753269093831_gcs_store
VERTEX_AI_SEARCH_LOCATION=global

# Vertex AI Agent Engine Configuration
# Agent Engine "strategy-supervisor-20250825-141622" is deployed in ken-e-dev project
# This supervisor has the V3 strategy agent with all fixes:
# - Module-level imports, root_agent alias, Optional types, Runner with InMemorySessionService
# - Fixed Runner.run() to use named parameters (user_id, session_id, new_message)
# - Fixed session creation before usage with create_session_sync()
# - Fixed message format to use Content object instead of string
# - Agents now fetch best practices and reviewer guidelines from Firestore
# - All agents output the exact fields defined in their best practices documents
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_AGENT_ENGINE_ID=projects/525657242938/locations/us-central1/reasoningEngines/3005383093130362880

# Google OAuth 2.0 Configuration for Google Analytics
# IMPORTANT: You need to set up these credentials in Google Cloud Console:
# 1. Go to APIs & Services > Credentials
# 2. Create OAuth 2.0 Client ID
# 3. Add authorized redirect URI: http://localhost:8000/api/oauth/callback/google
GOOGLE_OAUTH_CLIENT_ID=525657242938-g77npg1k1mk302g1kmthkmqhh2b7acal.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=sm://GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback/google
FRONTEND_URL=http://localhost:8080

# Encryption key for storing OAuth tokens (must be stable across restarts)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=***REMOVED***

# Google Analytics MCP Server Configuration
# This is the secured MCP server deployed in production that handles GA OAuth authentication
GA_MCP_SERVER_URL=https://google-analytics-mcp-4quwenkusq-uc.a.run.app
MCP_API_KEY=***REMOVED***

# W&B/Weave Configuration for observability
# For local dev: WANDB_API_KEY=your_actual_api_key_here
# For production: Using Secret Manager reference below
WANDB_API_KEY=sm://wandb_api_key
WANDB_PROJECT=ken-e-strategy-agent
WEAVE_PROJECT_NAME=ken-e-strategy-agent

# New Agent Engine IDs (using Secret Manager references)
# These will be resolved from Secret Manager at runtime when used by the API
KEN_E_ENGINE_ID=sm://525657242938/ken-e-engine-id
STRATEGY_SUPERVISOR_ENGINE_ID=sm://525657242938/strategy-supervisor-engine-id
OPENAI_API_KEY=sm://OPENAI_API_KEY
