# Vertex AI Configuration with Service Account
GOOGLE_CLOUD_PROJECT_ID=ken-e-staging
VERTEX_AI_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT=ken-e-staging
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
VERTEX_AI_STAGING_BUCKET=ken-e-staging-vertex-ai-staging

# Neo4j Database Configuration (Staging)
NEO4J_URI=sm://391472102753/NEO4J_URI
NEO4J_USERNAME=sm://391472102753/NEO4J_USERNAME
NEO4J_PASSWORD=sm://391472102753/NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# Firestore Configuration
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_PROJECT_ID=ken-e-staging

# Environment Indicator
ENVIRONMENT=staging
LOG_LEVEL=INFO

# Vertex AI Search Configuration
VERTEX_AI_SEARCH_ENGINE_ID=staging-strategy-docs-id
VERTEX_AI_SERVING_CONFIG_ID=default_config

# Company News Chatbot - Vertex AI Search Datastore
# This is the actual datastore ID from staging's Vertex AI Search (Discovery Engine)
VERTEX_AI_NEWS_DATASTORE_ID=ken-e-staging-test-news-search-connecto_1753269093831_gcs_store
VERTEX_AI_SEARCH_LOCATION=global

# NewsAPI.ai Configuration
NEWSAPI_AI_KEY=sm://391472102753/newsapi-ai-key

# Google Analytics MCP Server Configuration
GA_MCP_SERVER_URL=https://google-analytics-mcp-4quwenkusq-uc.a.run.app
MCP_API_KEY=sm://391472102753/mcp-api-key
GA_TENANT_ID=ken-e-staging

# Weights & Biases / Weave Observability
WANDB_API_KEY=sm://391472102753/wandb_api_key
WANDB_PROJECT=ken-e-staging
WEAVE_PROJECT_NAME=ken-e-staging
WANDB_ENTITY=ken-e

# Agent Engine IDs (Managed via Secret Manager)
KEN_E_ENGINE_ID=sm://391472102753/ken-e-engine-id
STRATEGY_SUPERVISOR_ENGINE_ID=sm://391472102753/strategy-supervisor-engine-id

# OpenAI API Key (for strategy formatters)
OPENAI_API_KEY=sm://391472102753/OPENAI_API_KEY

# Apache Superset Configuration
SUPERSET_BASE_URL=https://superset.ken-e.ai
SUPERSET_USERNAME=api
SUPERSET_PASSWORD=sm://391472102753/superset-password

# SendGrid Email Service
SENDGRID_API_KEY=sm://391472102753/sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@ken-e.ai
EMAIL_FROM_NAME=KEN-E Team
APP_BASE_URL=https://staging.app.ken-e.ai

# reCAPTCHA Configuration
RECAPTCHA_SITE_KEY=sm://391472102753/recaptcha-site-key
RECAPTCHA_SECRET_KEY=sm://391472102753/recaptcha-secret-key

# OAuth Configuration (staging-specific)
GOOGLE_OAUTH_CLIENT_ID=YOUR_STAGING_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=sm://391472102753/GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://kene-api-staging-391472102753.us-central1.run.app/api/oauth/callback/google
FRONTEND_URL=https://kene-frontend-staging-391472102753.us-central1.run.app

# Encryption Key (staging-specific)
ENCRYPTION_KEY=sm://391472102753/ENCRYPTION_KEY

# OpenTelemetry / Agent Engine Telemetry Configuration
# https://docs.cloud.google.com/agent-builder/agent-engine/manage/tracing
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
OTEL_SDK_DISABLED=false
