# Environment variables for KEN-E Strategy Agent (ADK/Agent Engine)
# Copy this file to .env and adjust values as needed

# ============================================================================
# SECRET MANAGER INTEGRATION
# ============================================================================
# This file supports Google Secret Manager references for sensitive credentials.
# Variables with sm:// prefix will be resolved from Secret Manager during deployment.
# The deployment script (deploy_with_sys_version.py) handles resolution.
# ============================================================================

# Neo4j Database Configuration
# Production/Staging: Use Secret Manager references
NEO4J_URI=sm://NEO4J_URI
NEO4J_USERNAME=sm://NEO4J_USERNAME
NEO4J_PASSWORD=sm://NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# For local development only (not for deployment):
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_password_here

# Google Cloud Configuration
# Firestore project ID - should match your Firebase Auth project
# GOOGLE_CLOUD_PROJECT_ID=ken-e-dev
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_PROJECT_ID=ken-e-dev

# Vertex AI Configuration
VERTEX_AI_PROJECT_ID=ken-e-dev
VERTEX_AI_LOCATION=us-central1

# Agent Engine ID (legacy - if needed for compatibility)
# This should point to an Agent Engine deployment
VERTEX_AI_AGENT_ENGINE_ID=projects/PROJECT_ID/locations/LOCATION/reasoningEngines/ENGINE_ID

# Logging
LOG_LEVEL=INFO

# Environment indicator
ENVIRONMENT=development

# Apache Superset Configuration
SUPERSET_BASE_URL=https://superset.ken-e.ai
SUPERSET_USERNAME=api
SUPERSET_PASSWORD=sm://superset-password
SUPERSET_DATABASE_ID=1

# SendGrid Email Service
SENDGRID_API_KEY=sm://sendgrid-api-key

# reCAPTCHA Configuration
RECAPTCHA_SITE_KEY=sm://recaptcha-site-key
RECAPTCHA_SECRET_KEY=sm://recaptcha-secret-key

# Google OAuth 2.0 for Google Analytics
# IMPORTANT: Each environment needs its own OAuth 2.0 Client
# See deployment/ENVIRONMENT_SETUP_GUIDE.md for setup instructions
GOOGLE_OAUTH_CLIENT_ID=YOUR_PROJECT_ID-xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=sm://GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback/google
FRONTEND_URL=http://localhost:8080

# Encryption Key for OAuth Tokens
# Each environment must have unique key - see ENVIRONMENT_SETUP_GUIDE.md
# For development: direct value
# For staging/production: sm://ENCRYPTION_KEY
ENCRYPTION_KEY=your_encryption_key_here

# Google Analytics MCP Server
GA_MCP_SERVER_URL=https://your-mcp-server.run.app
MCP_API_KEY=your_mcp_api_key_here

# Weights & Biases / Weave Observability
WANDB_API_KEY=sm://wandb_api_key
WANDB_PROJECT=ken-e-strategy-agent
WEAVE_PROJECT_NAME=ken-e-strategy-agent

# Agent Engine IDs (managed via Secret Manager)
KEN_E_ENGINE_ID=sm://ken-e-engine-id
STRATEGY_SUPERVISOR_ENGINE_ID=sm://strategy-supervisor-engine-id

# OpenAI API Key (for strategy formatters)
OPENAI_API_KEY=sm://OPENAI_API_KEY
