# Environment variables for Kene API
# Copy this file to .env.dev or .env.prod and adjust values as needed

# Application settings
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# CORS settings (adjust for production)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
ALLOWED_METHODS=GET,POST,PUT,DELETE
ALLOWED_HEADERS=*

# Neo4j Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Example for Neo4j AuraDB (cloud instance):
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_aura_password_here
# NEO4J_DATABASE=neo4j

# Apache Superset Configuration
SUPERSET_BASE_URL=https://your-superset-instance.com/
SUPERSET_USERNAME=your_superset_username
SUPERSET_PASSWORD=your_superset_password
SUPERSET_DATABASE_ID=superset_database_id

# Google Cloud Firestore Configuration
# Path to Google Cloud service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=./google-cloud-service-account-key.json
# Google Cloud project ID
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Firestore database ID (default: "(default)")
FIRESTORE_DATABASE_ID=your-database-id

# Logging level
LOG_LEVEL=INFO

# reCAPTCHA Configuration
# Get your keys from https://www.google.com/recaptcha/admin
# Use different keys for each environment (development, staging, production)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Redis Cache Configuration
# For local development: use localhost or Docker container name
# For production: use Google Cloud Memorystore IP address
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Set to true to suppress Redis connection warnings (useful for local dev without Redis)
SUPPRESS_REDIS_WARNING=false

# Vertex AI Agent Engine Configuration (for Chatbot)
# Location where your Agent Engine is deployed (typically us-central1)
VERTEX_AI_LOCATION=us-central1
# Full resource name of your deployed reasoning engine
# Format: projects/PROJECT_ID/locations/LOCATION/reasoningEngines/ENGINE_ID
VERTEX_AI_AGENT_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/your_engine_id

# Google OAuth 2.0 Configuration for Google Analytics
# IMPORTANT: You need to set up these credentials in Google Cloud Console:
# 1. Go to APIs & Services > Credentials
# 2. Create OAuth 2.0 Client ID
# 3. Add authorized redirect URI matching your environment
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
# For development: http://localhost:8000/api/oauth/callback/google
# For staging: https://staging-api.yourdomain.com/api/oauth/callback/google
# For production: https://api.yourdomain.com/api/oauth/callback/google
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback/google
# Frontend URL for post-auth redirect
FRONTEND_URL=http://localhost:8080

# Encryption key for securing OAuth tokens and sensitive credentials
# IMPORTANT: This key must be stable across application restarts
# Without a stable key, previously encrypted credentials cannot be decrypted
# 
# To generate a new encryption key, run one of these commands:
# Option 1 (if in API directory): uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Option 2 (with cryptography installed): python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 
# Security notes:
# - Keep this key secret and never commit it to version control
# - Use different keys for each environment (dev, staging, production)
# - Store production keys in secure secret management (e.g., Google Secret Manager)
# - Back up this key securely - losing it means losing access to encrypted data
ENCRYPTION_KEY=your_encryption_key_here
