# Environment variables for Kene API
# Copy this file to .env.dev or .env.prod and adjust values as needed

# ============================================================================
# SECRET MANAGER INTEGRATION
# ============================================================================
# This application supports Google Secret Manager for sensitive credentials.
# 
# You can use environment variables in two ways:
# 1. Direct values (for local development): VARIABLE_NAME=actual_value
# 2. Secret Manager references: VARIABLE_NAME=sm://project_id/secret_name
#    or VARIABLE_NAME=sm://secret_name (uses GOOGLE_CLOUD_PROJECT)
#
# When using the sm:// prefix, the application will fetch the actual value
# from Google Secret Manager at runtime. This requires:
# - Google Cloud authentication (via gcloud auth or service account)
# - Secret Manager Secret Accessor role on the specified secrets
#
# Examples:
# Local development: WANDB_API_KEY=your_actual_api_key_here
# Production: WANDB_API_KEY=sm://525657242938/wandb_api_key
# ============================================================================

# Application settings
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# CORS settings (adjust for production)
# Note: ALLOWED_* variables are deprecated, use CORS_* instead
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_METHODS=GET,POST,PUT,DELETE
CORS_HEADERS=*

# Environment indicator (development, staging, production)
ENVIRONMENT=development

# Neo4j Database Configuration
# For production/staging, use Secret Manager references:
NEO4J_URI=sm://NEO4J_URI
NEO4J_USERNAME=sm://NEO4J_USERNAME
NEO4J_PASSWORD=sm://NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# For local development, you can use direct values:
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_password_here

# Example for Neo4j AuraDB (cloud instance):
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_aura_password_here
# NEO4J_DATABASE=neo4j

# Apache Superset Configuration
SUPERSET_BASE_URL=https://your-superset-instance.com/
SUPERSET_USERNAME=your_superset_username
SUPERSET_PASSWORD=sm://superset-password
SUPERSET_DATABASE_ID=superset_database_id

# Google Cloud Firestore and Secret Manager Configuration
# GOOGLE_CLOUD_PROJECT is used for Secret Manager and default project references
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_PROJECT_ID is used for Firestore
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Path to Google Cloud service account key JSON file (optional for local dev if using gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS=./google-cloud-service-account-key.json
# Firestore database ID (default: "(default)")
FIRESTORE_DATABASE_ID=(default)

# Logging level
LOG_LEVEL=INFO

# reCAPTCHA Configuration
# Get your keys from https://www.google.com/recaptcha/admin
# Production should use Secret Manager:
RECAPTCHA_SITE_KEY=sm://recaptcha-site-key
RECAPTCHA_SECRET_KEY=sm://recaptcha-secret-key
# For local development: RECAPTCHA_SITE_KEY=your_actual_site_key

# Redis Cache Configuration
# For local development: use localhost or Docker container name
# For production: use Google Cloud Memorystore IP address
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Set to true to suppress Redis connection warnings (useful for local dev without Redis)
SUPPRESS_REDIS_WARNING=false

# Vertex AI Agent Engine Configuration (for Chatbot)
# Location where your Agent Engine is deployed (typically us-central1)
VERTEX_AI_LOCATION=us-central1
# Full resource name of your deployed reasoning engine
# Format: projects/PROJECT_ID/locations/LOCATION/reasoningEngines/ENGINE_ID
# Agent Engine IDs for separated agents
# KEN-E Agent for chat interactions (frontend)
# Local: KEN_E_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/ken_e_engine_id
# Production with Secret Manager: KEN_E_ENGINE_ID=sm://525657242938/ken-e-engine-id
KEN_E_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/ken_e_engine_id
# Strategy Supervisor for account creation (backend)
# Local: STRATEGY_SUPERVISOR_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/strategy_engine_id
# Production with Secret Manager: STRATEGY_SUPERVISOR_ENGINE_ID=sm://525657242938/strategy-supervisor-engine-id
STRATEGY_SUPERVISOR_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/strategy_engine_id
# Legacy: Kept for backward compatibility (point to KEN-E)
# Local: VERTEX_AI_AGENT_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/ken_e_engine_id
# Production with Secret Manager: VERTEX_AI_AGENT_ENGINE_ID=sm://525657242938/ken-e-engine-id
VERTEX_AI_AGENT_ENGINE_ID=projects/your-project-id/locations/us-central1/reasoningEngines/ken_e_engine_id

# Google OAuth 2.0 Configuration for Google Analytics
# ============================================================================
# IMPORTANT: Each environment MUST have its own OAuth 2.0 Client
#
# Setup Steps (per environment):
# 1. Go to: https://console.cloud.google.com/apis/credentials?project=YOUR_PROJECT
# 2. Click: "Create Credentials" → "OAuth 2.0 Client ID"
# 3. Choose: "Web application" as application type
# 4. Configure Authorized redirect URIs:
#    - Development: http://localhost:8000/api/oauth/callback/google
#    - Staging: https://staging-api.ken-e.ai/api/oauth/callback/google
#    - Production: https://api.ken-e.ai/api/oauth/callback/google
# 5. Google will generate Client ID and Client Secret - copy both
# 6. Store in Secret Manager (recommended for staging/production)
#
# SECURITY WARNING:
# - DO NOT copy dev credentials to staging/production (different redirect URIs!)
# - DO NOT commit client secrets to version control
# - Each environment needs separate OAuth 2.0 Clients
# ============================================================================

# Client ID (public, safe to hardcode or use Secret Manager)
GOOGLE_OAUTH_CLIENT_ID=525657242938-xxxxx.apps.googleusercontent.com

# Client Secret (SENSITIVE - use Secret Manager for staging/production)
# Development: GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx
# Staging/Production: GOOGLE_OAUTH_CLIENT_SECRET=sm://GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_CLIENT_SECRET=sm://GOOGLE_OAUTH_CLIENT_SECRET

# Redirect URI (must match OAuth client configuration)
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback/google

# Frontend URL for post-auth redirect
FRONTEND_URL=http://localhost:8080

# Encryption key for securing OAuth tokens and sensitive credentials
# ============================================================================
# IMPORTANT: Each environment MUST have its own unique encryption key
#
# Setup Steps (per environment):
# 1. Generate a new unique key for this environment:
#    uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# 2. For Development:
#    - Copy the generated key directly to .env.development
#    - ENCRYPTION_KEY=generated_key_here
#
# 3. For Staging/Production:
#    - Create secret in Secret Manager:
#      echo "generated_key_here" | gcloud secrets create ENCRYPTION_KEY --data-file=- --project=PROJECT_ID
#    - Reference in .env:
#      ENCRYPTION_KEY=sm://ENCRYPTION_KEY
#
# CRITICAL SECURITY NOTES:
# - Each environment MUST use a different key (security isolation)
# - NEVER copy keys between environments
# - NEVER commit encryption keys to version control
# - Back up keys securely - losing a key means losing all encrypted data
# - Key must be stable across application restarts within same environment
# - If you rotate a key, you must re-encrypt all existing encrypted data
# ============================================================================

# For development (direct value)
# ENCRYPTION_KEY=***REMOVED***

# For staging/production (Secret Manager)
ENCRYPTION_KEY=sm://ENCRYPTION_KEY

# OpenAI Configuration (for strategy formatters)
OPENAI_API_KEY=sm://OPENAI_API_KEY

# SendGrid Email Service
# For production/staging: Use Secret Manager
SENDGRID_API_KEY=sm://sendgrid-api-key
# For local development: Either use sm:// (requires gcloud auth) or direct value
# SENDGRID_API_KEY=SG.your-direct-api-key-here
EMAIL_FROM_ADDRESS=noreply@ken-e.ai
EMAIL_FROM_NAME=KEN-E Team
# APP_BASE_URL should match your frontend URL
APP_BASE_URL=http://localhost:8080

# Vertex AI Project Configuration
VERTEX_AI_PROJECT_ID=your-gcp-project-id

# Google Analytics MCP Server
GA_MCP_SERVER_URL=http://localhost:8080
MCP_API_KEY=your-mcp-api-key

# Weights & Biases / Weave Observability
WANDB_API_KEY=sm://wandb_api_key
WANDB_PROJECT=ken-e-strategy-agent
WANDB_ENTITY=ken-e
WEAVE_PROJECT_NAME=ken-e-strategy-agent

# Google Cloud KMS (for encryption in production)
USE_LOCAL_ENCRYPTION=true
KMS_LOCATION_ID=us-central1
KMS_KEY_RING_ID=your-keyring-id
KMS_KEY_ID=your-key-id

# Authentication settings
USE_APPLICATION_DEFAULT_CREDENTIALS=false

# AI Model Configuration
GEMINI_MODEL=gemini-2.0-flash

# Organization Creation Permissions
# Options: "all" (any authenticated user), "super_admin" (only super admins), "none" (disabled)
ORGANIZATION_CREATION_PERMISSION=all
