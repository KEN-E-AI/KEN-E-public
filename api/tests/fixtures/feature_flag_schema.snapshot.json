{
  "$defs": {
    "TargetingRules": {
      "properties": {
        "account_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 1000,
          "title": "Account Ids",
          "type": "array"
        },
        "email_domains": {
          "items": {
            "type": "string"
          },
          "maxItems": 1000,
          "title": "Email Domains",
          "type": "array"
        },
        "organization_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 1000,
          "title": "Organization Ids",
          "type": "array"
        },
        "rollout_percentage": {
          "default": 0,
          "maximum": 100,
          "minimum": 0,
          "title": "Rollout Percentage",
          "type": "integer"
        },
        "user_emails": {
          "items": {
            "type": "string"
          },
          "maxItems": 1000,
          "title": "User Emails",
          "type": "array"
        }
      },
      "title": "TargetingRules",
      "type": "object"
    }
  },
  "properties": {
    "bucketing_entity": {
      "default": "account",
      "enum": [
        "account",
        "organization",
        "user"
      ],
      "title": "Bucketing Entity",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "default_enabled": {
      "title": "Default Enabled",
      "type": "boolean"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "expected_ga_release": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expected Ga Release"
    },
    "is_active": {
      "default": true,
      "title": "Is Active",
      "type": "boolean"
    },
    "key": {
      "pattern": "^[a-z0-9][a-z0-9_]{2,63}$",
      "title": "Key",
      "type": "string"
    },
    "owner": {
      "title": "Owner",
      "type": "string"
    },
    "targeting_rules": {
      "$ref": "#/$defs/TargetingRules"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "key",
    "description",
    "default_enabled",
    "owner",
    "created_at",
    "updated_at"
  ],
  "title": "FeatureFlag",
  "type": "object"
}
